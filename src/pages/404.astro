---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page not found" description="The page you're looking for doesn't exist.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center px-5 text-center">
    <p class="font-mono text-sm font-bold text-accent-500">404</p>
    <h1 class="mt-2 text-4xl font-black">Page not found</h1>
    <p class="mt-3 max-w-md text-gray-500">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn btn-primary mt-8">Back to Home →</a>
  </section>
</Base>
